<div class="cart-page">
  <div class="container">
    <h1 class="cart-title">Il tuo carrello</h1>
    {% if cart.item_count == 0 %}
      <div class="cart-empty">
        <div class="cart-empty-icon">🛒</div>
        <h2>Il carrello è vuoto</h2>
        <p>Aggiungi qualcosa per iniziare!</p>
        <a href="/collections/all" class="btn-primary">Vai al catalogo</a>
      </div>
    {% else %}
      {% form 'cart', cart %}
        <div class="cart-layout">
          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item">
                <div class="cart-item-img">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title }}" />
                  {% else %}
                    <div class="cart-item-no-img">📦</div>
                  {% endif %}
                </div>
                <div class="cart-item-info">
                  <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                  {% unless item.variant.title == 'Default Title' %}
                    <p class="cart-item-variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  <p class="cart-item-price">CHF {{ item.price | money_without_currency }}</p>
                </div>
                <div class="cart-item-qty">
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="qty-input" />
                </div>
                <div class="cart-item-total">
                  CHF {{ item.line_price | money_without_currency }}
                </div>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="cart-item-remove">✕</a>
              </div>
            {% endfor %}
          </div>
          <div class="cart-summary">
            <h3>Riepilogo ordine</h3>
            <div class="cart-summary-row">
              <span>Subtotale</span>
              <span>CHF {{ cart.total_price | money_without_currency }}</span>
            </div>
            <p class="cart-shipping-note">Spedizione calcolata al checkout</p>
            <button type="submit" name="checkout" class="btn-checkout">
              Procedi al checkout →
            </button>
            <a href="/collections/all" class="btn-continue">← Continua gli acquisti</a>
          </div>
        </div>
      {% endform %}
    {% endif %}
  </div>
</div>

<style>
.cart-page { padding: 100px 0 60px; min-height: 70vh; }
.cart-title { font-size: 2rem; font-weight: 800; color: #1B2A4A; margin-bottom: 36px; }
.cart-empty { text-align: center; padding: 60px 0; }
.cart-empty-icon { font-size: 4rem; margin-bottom: 16px; }
.cart-empty h2 { font-size: 1.5rem; color: #1B2A4A; margin-bottom: 8px; }
.cart-empty p { color: #666; margin-bottom: 24px; }
.cart-layout { display: grid; grid-template-columns: 1fr 340px; gap: 40px; align-items: start; }
.cart-item { display: grid; grid-template-columns: 80px 1fr auto auto auto; gap: 16px; align-items: center; padding: 20px 0; border-bottom: 1px solid #f1f3f5; }
.cart-item-img img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; }
.cart-item-no-img { width: 80px; height: 80px; background: #f8f9fa; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
.cart-item-info h3 { font-size: 0.95rem; font-weight: 600; color: #1B2A4A; margin-bottom: 4px; }
.cart-item-info h3 a { text-decoration: none; color: inherit; }
.cart-item-variant { color: #888; font-size: 0.85rem; }
.cart-item-price { color: #FF6B35; font-weight: 600; font-size: 0.9rem; margin-top: 4px; }
.qty-input { width: 60px; padding: 8px; border: 2px solid #dee2e6; border-radius: 8px; text-align: center; font-size: 1rem; }
.cart-item-total { font-weight: 700; color: #1B2A4A; white-space: nowrap; }
.cart-item-remove { color: #aaa; text-decoration: none; font-size: 1.2rem; }
.cart-item-remove:hover { color: #FF6B35; }
.cart-summary { background: #f8f9fa; border-radius: 14px; padding: 28px; position: sticky; top: 100px; }
.cart-summary h3 { font-size: 1.1rem; font-weight: 700; color: #1B2A4A; margin-bottom: 20px; }
.cart-summary-row { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 1rem; }
.cart-summary-row span:last-child { font-weight: 700; }
.cart-shipping-note { color: #888; font-size: 0.85rem; margin-bottom: 20px; }
.btn-checkout { width: 100%; background: #FF6B35; color: white; border: none; padding: 16px; border-radius: 50px; font-size: 1rem; font-weight: 700; cursor: pointer; margin-bottom: 12px; }
.btn-checkout:hover { background: #e55a24; }
.btn-continue { display: block; text-align: center; color: #666; font-size: 0.9rem; text-decoration: none; }
.btn-continue:hover { color: #FF6B35; }
@media (max-width: 768px) { .cart-layout { grid-template-columns: 1fr; } .cart-item { grid-template-columns: 60px 1fr; } }
</style>
