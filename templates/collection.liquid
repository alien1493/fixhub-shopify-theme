<div class="collection-page">
  <div class="container">
    <div class="collection-header">
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="collection-description">{{ collection.description }}</div>
      {% endif %}
    </div>
    {% if collection.products.size == 0 %}
      <div class="collection-empty">
        <p>Nessun prodotto disponibile al momento.</p>
        <a href="/collections/all" class="btn-primary">Vedi tutto il catalogo</a>
      </div>
    {% else %}
      <div class="products-grid">
        {% for product in collection.products %}
          <div class="product-card">
            <a href="{{ product.url }}" class="product-card-link">
              <div class="product-card-img">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" />
                {% else %}
                  <div class="product-card-no-img">📦</div>
                {% endif %}
              </div>
              <div class="product-card-info">
                {% if product.type != blank %}
                  <span class="product-card-type">{{ product.type }}</span>
                {% endif %}
                <h3 class="product-card-title">{{ product.title }}</h3>
                <div class="product-card-price">
                  {% if product.compare_at_price > product.price %}
                    <span class="price-old">CHF {{ product.compare_at_price | money_without_currency }}</span>
                  {% endif %}
                  <span class="price-now">CHF {{ product.price | money_without_currency }}</span>
                </div>
                {% unless product.available %}
                  <span class="sold-out-badge">Esaurito</span>
                {% endunless %}
              </div>
            </a>
            {% if product.available %}
              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                <button type="submit" class="btn-quick-add">🛒 Aggiungi al carrello</button>
              </form>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
.collection-page { padding: 100px 0 60px; }
.collection-header { margin-bottom: 40px; }
.collection-header h1 { font-size: 2rem; font-weight: 800; color: #1B2A4A; margin-bottom: 12px; }
.collection-description { color: #666; font-size: 1rem; max-width: 600px; }
.collection-empty { text-align: center; padding: 60px 0; color: #666; }
.products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; }
.product-card { background: white; border: 1px solid #dee2e6; border-radius: 14px; overflow: hidden; transition: box-shadow 0.2s, transform 0.2s; }
.product-card:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.12); transform: translateY(-3px); }
.product-card-link { text-decoration: none; color: inherit; display: block; }
.product-card-img { aspect-ratio: 1; overflow: hidden; background: #f8f9fa; }
.product-card-img img { width: 100%; height: 100%; object-fit: cover; }
.product-card-no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; }
.product-card-info { padding: 16px; }
.product-card-type { font-size: 0.75rem; color: #FF6B35; font-weight: 600; text-transform: uppercase; }
.product-card-title { font-size: 0.95rem; font-weight: 700; color: #1B2A4A; margin: 6px 0 10px; }
.price-old { font-size: 0.85rem; color: #aaa; text-decoration: line-through; margin-right: 8px; }
.price-now { font-size: 1.1rem; font-weight: 700; color: #FF6B35; }
.sold-out-badge { background: #f1f3f5; color: #888; font-size: 0.75rem; padding: 4px 10px; border-radius: 50px; }
.btn-quick-add { width: 100%; background: #1B2A4A; color: white; border: none; padding: 12px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
.btn-quick-add:hover { background: #FF6B35; }
</style>
